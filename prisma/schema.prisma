// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  ADMIN
  OWNER
  FUNCIONARIO
}

model Users {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  Role       Roles       @default(FUNCIONARIO)
  storeID    Store[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  userStores UserStore[]
  clients    Client[]
}

model Store {
  id           String      @id @default(cuid())
  name         String
  road         String
  neighborhood String
  number       String
  city         String
  state        String
  zipCode      String
  document     String      @unique
  phone        String
  user         Users[]
  userStores   UserStore[]
  clients      Client[]
}

model UserStore {
  userId  String
  storeId String

  user  Users @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@id([userId, storeId])
}

model Client {
  id String @id @default(cuid())

  name     String
  document String @unique

  birthDate DateTime?

  phone String
  email String?

  zipCode      String
  road         String
  number       String
  neighborhood String
  city         String
  state        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  createdById String?
  createdBy   Users?  @relation(fields: [createdById], references: [id])
}

model Supplier {
  id String @id @default(cuid())

  active   Boolean
  name     String
  document String @unique

  phone        String
  email        String?
  website      String?
  nameContact  String?
  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
